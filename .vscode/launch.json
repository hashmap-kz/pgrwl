{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "backup",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/main.go",
      "buildFlags": "-tags=debug",
      "args": [
        "backup",
        "-c",
        "${workspaceFolder}/hack/configs/localfs/receive.yml"
      ],
      "envFile": "${workspaceFolder}/.vscode/pg.env"
    },
    {
      "name": "receive",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/main.go",
      "buildFlags": "-tags=debug",
      "args": [
        "daemon",
        "-c",
        "${workspaceFolder}/hack/configs/localfs/receive.yml",
        "-m",
        "receive"
      ],
      "envFile": "${workspaceFolder}/.vscode/pg.env",
      "env": {
        "TZ": "UTC"
      }
    },
    {
      "name": "receive-combined",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/main.go",
      "buildFlags": "-tags=debug",
      "args": [
        "daemon",
        "-c",
        "${workspaceFolder}/hack/configs/localfs/receive.yml",
        "-m",
        "combined"
      ],
      "envFile": "${workspaceFolder}/.vscode/pg.env",
      "env": {
        "TZ": "UTC"
      }
    }
  ]
}