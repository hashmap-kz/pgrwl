{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "receive",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/cmd/pgrwl/main.go",
      "buildFlags": "-tags=debug",
      "args": [
        "daemon",
        "-c",
        "${workspaceFolder}/hack/configs/localfs/receive.yml",
        "-m",
        "receive"
      ],
      "envFile": "${workspaceFolder}/.vscode/pg.env",
      "env": {
        "TZ": "UTC"
      }
    },
    {
      "name": "backup-cmd",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/cmd/pgrwl/main.go",
      "buildFlags": "-tags=debug",
      "args": [
        "backup",
        "-c",
        "${workspaceFolder}/hack/configs/localfs/receive.yml"
      ],
      "envFile": "${workspaceFolder}/.vscode/pg.env"
    },
    {
      "name": "restore-cmd",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/cmd/pgrwl/main.go",
      "buildFlags": "-tags=debug",
      "args": [
        "restore",
        "-c",
        "${workspaceFolder}/hack/configs/localfs/receive.yml",
        "--dest",
        "restore_test"
      ],
      "envFile": "${workspaceFolder}/.vscode/pg.env"
    },
    {
      "name": "ui",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/cmd/pgrwl-ui/main.go",
      "buildFlags": "-tags=debug",
      "env": {
        "PGRWL_UI_CONFIG_PATH": "${workspaceFolder}/hack/configs/ui/pgrwl-ui.yml"
      }
    }
  ]
}
